class Solution {
    public int majorityElement(int[] nums) {
        int n=nums.length,count=1,ans=nums[0];
        for(int i=1;i<n;i++){
            if(nums[i]==ans){
                count++;
            }else{
                count--;
            }
            if(count==0){
                ans=nums[i];
                count=1;
            }
        }

        return ans;
    }
}
